{
  "name": "@cumulus/cnm-to-cma",
  "version": "21.3.2",
  "description": "CNM to CMA task",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "homepage": "https://github.com/nasa/cumulus/tree/master/tasks/cnm-to-cma",
  "repository": {
    "type": "git",
    "url": "https://github.com/nasa/cumulus",
    "directory": "tasks/cnm-to-cma"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && mkdir dist && npm run generate-task-schemas && cp -R schemas dist/",
    "clean": "rm -rf dist && rm -rf .venv && mkdir dist",
    "generate-task-schemas": "uv run generate-task-schemas ./schemas",
    "lint": "uv run ruff check . && uv run ruff format --diff . && uv run mypy src/cnm_to_cma",
    "package": "npm run clean && ../../bin/package_uv.sh 3.12 ${PWD}",
    "update-python-version": "uv version --",
    "test": "uv run pytest -q",
    "uv-export": "uv export -q --no-header --format requirements-txt --output-file requirements.txt",
    "uv-lock": "uv lock --upgrade"
  },
  "author": "Cumulus Author : Cumulus Coreification Team",
  "license": "Apache-2.0"
}
